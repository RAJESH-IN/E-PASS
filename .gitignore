# ══════════════════════════════════════════
# MyPass — .gitignore
# Angular 17 + .NET 8 + SQL Server
# ══════════════════════════════════════════

# ── .NET Backend ───────────────────────────
bin/
obj/
*.user
*.suo
.vs/
*.log
*.tlog
*.ilk
*.pdb
*.opencover.xml
TestResults/

# Sensitive config — never commit these
appsettings.Production.json
appsettings.Staging.json
secrets.json
*.pfx
*.p12
*.key

# ── Angular Frontend ────────────────────────
node_modules/
dist/
.angular/
*.js.map
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS Files ────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
ehthumbs.db

# ── IDE / Editor ────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Misc ────────────────────────────────────
*.zip
*.tar.gz
publish/